# Supabase — powers live order status + kitchen dashboard (Phase 2).
# Create a free project at https://supabase.com, then copy these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (used by the kitchen dashboard for privileged updates).
SUPABASE_SERVICE_ROLE_KEY=

# Image generation (used only by scripts/gen-images.mjs).
# Falls back to ../shared-keys/fal.env if unset.
FAL_KEY=
