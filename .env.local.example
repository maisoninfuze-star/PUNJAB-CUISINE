# Supabase — the database for orders + customer accounts + marketing list.
# REQUIRED in production (Vercel): without it the app falls back to a local
# file store that does NOT persist on serverless. Steps:
#   1. Create a free project at https://supabase.com
#   2. Run supabase/schema.sql in the project's SQL Editor
#   3. Copy these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service_role key (bypasses RLS; all DB access is server-side).
SUPABASE_SERVICE_ROLE_KEY=

# Image generation (used only by scripts/gen-images.mjs).
# Falls back to ../shared-keys/fal.env if unset.
FAL_KEY=

# Owner dashboard passcode (kitchen board + customer list). Defaults to
# "punjabi2024" in dev if unset.
OWNER_PASSCODE=

# Secret used to sign customer login session cookies. Set to a long random
# string in production (e.g. `openssl rand -hex 32`). A dev fallback is used
# if unset, so accounts work locally out of the box.
AUTH_SECRET=

# Order confirmation emails (optional). Both must be set to switch emails on;
# otherwise ordering works fine and no email is sent. Get a key at
# https://resend.com and verify your sending domain, then set RESEND_FROM to a
# from-address on that domain.
RESEND_API_KEY=
RESEND_FROM="Punjabi Cuisine <orders@yourdomain.com>"
